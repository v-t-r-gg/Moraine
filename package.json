{
  "name": "moraine",
  "version": "0.1.0",
  "description": "Local-first ledger for autonomous agent work",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "cli": "cargo run -p moraine-cli --",
    "server": "cargo run -p moraine-server",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cargo test -p moraine-core && cargo build -p moraine-cli -q && cargo test -p moraine-cli && cargo test -p moraine-mcp",
    "fmt:rust": "cargo fmt --all",
    "lint:rust": "cargo clippy -p moraine-core -p moraine-cli -p moraine-mcp -p moraine-server -- -D warnings",
    "check:all": "bash scripts/check.sh"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-collaboration": "^2.11.5",
    "@tiptap/extension-collaboration-cursor": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "marked": "^15.0.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tiptap-markdown": "^0.8.10",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.24"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.3",
    "vite": "^6.0.11",
    "vitest": "^3.0.5"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
