{
  "name": "moraine",
  "version": "0.1.0",
  "description": "Local-first review ledger for autonomous agent work",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "cli": "cargo run -p moraine-cli --",
    "server": "cargo run -p moraine-server",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cargo test -p moraine-core && cargo test -p moraine-cli",
    "fmt:rust": "cargo fmt --all",
    "lint:rust": "cargo clippy -p moraine-core -p moraine-cli -p moraine-server -- -D warnings",
    "check:all": "bash scripts/check.sh"
  },
  "license": "MIT OR Apache-2.0",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-collaboration": "^2.11.5",
    "@tiptap/extension-collaboration-cursor": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "marked": "^15.0.7",
    "tiptap-markdown": "^0.8.10",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.24"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.17.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/typography": "^0.5.16",
    "@tauri-apps/cli": "^2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.3",
    "vite": "^6.0.11",
    "vitest": "^3.0.5"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
